# ──────────────────────────────────────────────────────────────
#  Phishing Triage Bot – Environment Variables
#  Copy this file to .env and fill in your real keys.
# ──────────────────────────────────────────────────────────────

# Telegram Bot token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Comma-separated list of Telegram chat IDs allowed to use the bot.
# Leave empty to allow all chats (not recommended for production).
ALLOWED_CHAT_IDS=

# ── Threat Intelligence APIs ─────────────────────────────────

# VirusTotal API key (https://www.virustotal.com/gui/my-apikey)
VIRUSTOTAL_API_KEY=

# AlienVault OTX API key (https://otx.alienvault.com/accounts/signup)
ALIENVAULT_OTX_API_KEY=

# AbuseIPDB API key (https://www.abuseipdb.com/account/api)
ABUSEIPDB_API_KEY=

# SecurityTrails API key (https://securitytrails.com/app/signup)
SECURITYTRAILS_API_KEY=

# ── AI Classifier ────────────────────────────────────────────

# Groq API key (https://console.groq.com/keys)
GROQ_API_KEY=

# ── Optional Tuning ──────────────────────────────────────────

# Risk scoring thresholds (defaults: HIGH=70, MEDIUM=40)
# RISK_HIGH_THRESHOLD=70
# RISK_MEDIUM_THRESHOLD=40

# Log level (default: INFO)
# LOG_LEVEL=INFO
GROQ_MODEL=llama-3.3-70b-versatile

# Risk scoring thresholds (0-100)
RISK_HIGH_THRESHOLD=70
RISK_MEDIUM_THRESHOLD=40

# Directory to store uploaded .eml files and extracted attachments
UPLOAD_DIR=uploads

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
